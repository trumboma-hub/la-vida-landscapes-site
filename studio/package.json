    "react-dom": "^18.3.1",
    "sanity": "4.22.0",
    "styled-components": "^6.1.13"
  },
  "devDependencies": {
    "@sanity/eslint-config-studio": "^4.0.0",
    "@types/react": "^18.3.5",
    "eslint": "^9.9.0",
    "prettier": "^3.3.3",
    "typescript": "^5.5.4"
  },
  "overrides": {
    "glob": ">=10.5.0",
    "prismjs": ">=1.30.0"
