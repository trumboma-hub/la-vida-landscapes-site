{
  "name": "la-vida-studio",
  "private": true,
  "version": "0.1.0",
  "description": "La Vida Landscapes — Sanity Studio for the Journal",
  "engines": {
    "node": "22.x",
    "npm": ">=11.0.0"
  },
  "packageManager": "npm@11.6.2",
  "scripts": {
